# ---------------------------------------------------------------------------
# Daily Quiz — environment variables (server-side only; never exposed to browser)
#
# Local dev with Cloudflare adapter reads secrets from `.dev.vars` (same KEY=value
# format). Copy these keys into `.dev.vars` for `yarn dev`. For production, set them
# as Worker secrets:  wrangler secret put OPENAI_API_KEY   (etc.)
# ---------------------------------------------------------------------------

# OpenAI (provider chosen for this app)
OPENAI_API_KEY=
# Optional — defaults to gpt-4o if unset
OPENAI_MODEL=gpt-4o
# Optional — for OpenAI-compatible/proxy endpoints
# OPENAI_BASE_URL=

# Supabase
SUPABASE_URL=
# Service role key: server-side ONLY. Never ship to the client.
SUPABASE_SERVICE_ROLE_KEY=
# Anon key (optional; not required by the current server-only data flow)
SUPABASE_ANON_KEY=


